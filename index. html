<meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Calculus in Agriculture: Oil Palm Growth Rates</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap');
        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
        }
    </style>
</head>
<body class="bg-slate-50 text-slate-800 min-h-screen flex flex-col justify-between">

    <header class="bg-emerald-800 text-white py-6 px-4 shadow-md">
        <div class="max-w-6xl mx-auto flex flex-col md:flex-row justify-between items-center gap-4">
            <div>
                <span class="bg-emerald-600 text-xs font-semibold uppercase tracking-wider px-2.5 py-1 rounded-full text-emerald-100">
                    Agro-Product Technology Application
                </span>
                <h1 class="text-2xl md:text-3xl font-bold mt-2">Optimizing Oil Palm Fruit Bunch Yield via Derivatives</h1>
            </div>
            <div class="text-right md:text-right text-sm text-emerald-200">
                <p class="font-medium">Calculus & Bioscience Interactive Lab</p>
                <p class="text-xs opacity-75">Tailored for Malaysian Agro-Technology Frameworks</p>
            </div>
        </div>
    </header>

    <main class="max-w-6xl mx-auto p-4 md:p-6 grid grid-cols-1 lg:grid-cols-3 gap-6 flex-grow w-full">
        
        <section class="lg:col-span-1 bg-white p-6 rounded-2xl shadow-xs border border-slate-100 flex flex-col justify-between gap-6">
            <div>
                <h2 class="text-xl font-bold text-slate-900 border-b pb-2 border-slate-100 mb-4">The Bioscience Problem</h2>
                <p class="text-slate-600 text-sm leading-relaxed mb-4">
                    In Malaysia's palm oil industry, tracking the mass accumulation rate of Fresh Fruit Bunches (FFB) is vital for harvesting logistics. If harvested too early, oil content is substandard; too late, and free fatty acids degrade the quality. 
                </p>
                <p class="text-slate-600 text-sm leading-relaxed mb-4">
                    Based on growth metrics analogous to data published by the <strong>Malaysian Palm Oil Board (MPOB)</strong>, FFB accumulation during the peak 30-day ripening phase follows a classic sigmoidal logistic curve. 
                </p>
                <p class="text-slate-600 text-sm leading-relaxed">
                    By applying the <strong>first derivative $f'(x)$</strong>, we pinpoint the exact day the fruit is gaining weight the fastest—the <em>Inflection Point</em>—which dictates peak metabolic activity and helps predict optimal harvest windows.
                </p>
            </div>

            <div class="bg-emerald-50/50 p-4 rounded-xl border border-emerald-100">
                <h3 class="text-sm font-semibold text-emerald-900 mb-3 flex items-center gap-2">
                    <svg class="w-4 h-4 text-emerald-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 2 0 002-2V5a2 2 2 0 00-2-2H7a2 2 2 0 00-2 2v14a2 2 2 0 002 2z"></path></svg>
                    The Mathematical Model
                </h3>
                
                <div class="mb-4">
                    <span class="text-xs font-bold text-emerald-800 uppercase block mb-1">FFB Mass Function $f(x)$</span>
                    <div class="bg-white p-2.5 rounded shadow-2xs font-mono text-xs text-center border border-emerald-200">
                        $$f(x) = \frac{25}{1 + e^{-0.25(x - 15)}}$$
                    </div>
                    <span class="text-[11px] text-slate-500 mt-1 block">Yields total mass ($kg$) at day $x$.</span>
                </div>

                <div>
                    <span class="text-xs font-bold text-emerald-800 uppercase block mb-1">Growth Rate Derivative $f'(x)$</span>
                    <div class="bg-white p-2.5 rounded shadow-2xs font-mono text-xs text-center border border-emerald-200">
                        $$f'(x) = \frac{6.25 \cdot e^{-0.25(x - 15)}}{\left(1 + e^{-0.25(x - 15)}\right)^2}$$
                    </div>
                    <span class="text-[11px] text-slate-500 mt-1 block">Yields growth rate ($kg/day$) at day $x$.</span>
                </div>
            </div>
        </section>

        <section class="lg:col-span-2 flex flex-col gap-6">
            
            <div class="bg-white p-6 rounded-2xl shadow-xs border border-slate-100 flex-grow">
                <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-2 mb-4">
                    <div>
                        <h2 class="text-xl font-bold text-slate-900">FFB Ripening Vector Tracking</h2>
                        <p class="text-xs text-slate-500">Click anywhere on the plot line to calculate the local derivative instantly.</p>
                    </div>
                    <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md text-xs font-medium bg-amber-50 text-amber-800 border border-amber-200">
                        <span class="w-1.5 h-1.5 rounded-full bg-amber-500 animate-pulse"></span>
                        Interactive Graph
                    </span>
                </div>
                
                <div class="relative w-full h-64 md:h-80">
                    <canvas id="growthChart"></canvas>
                </div>
            </div>

            <div id="inspector-panel" class="bg-slate-900 text-slate-100 p-5 rounded-2xl shadow-md transition-all duration-300 border border-slate-800">
                <div class="flex items-center justify-between border-b border-slate-800 pb-3 mb-3">
                    <div class="flex items-center gap-2">
                        <div class="w-2.5 h-2.5 rounded-full bg-emerald-500"></div>
                        <h3 class="text-xs font-bold uppercase tracking-wider text-slate-400">Calculus Interpreter Terminal</h3>
                    </div>
                    <span class="text-[10px] bg-slate-800 px-2 py-0.5 rounded text-slate-400 font-mono">Status: Ready</span>
                </div>

                <div id="inspector-prompt" class="py-4 text-center text-slate-500 text-sm">
                    💡 Click on any point along the curve above to compute the derivative $f'(x)$.
                </div>

                <div id="inspector-results" class="hidden grid grid-cols-1 md:grid-cols-3 gap-4 items-center">
                    <div class="bg-slate-800/50 p-3 rounded-xl border border-slate-800 text-center">
                        <p class="text-xs text-slate-400 uppercase font-semibold">Selected Point ($x$)</p>
                        <p class="text-xl font-bold text-white mt-1" id="out-day">Day --</p>
                    </div>
                    <div class="bg-slate-800/50 p-3 rounded-xl border border-slate-800 text-center">
                        <p class="text-xs text-slate-400 uppercase font-semibold">Bunch Weight $f(x)$</p>
                        <p class="text-xl font-bold text-sky-400 mt-1" id="out-mass">-- kg</p>
                    </div>
                    <div class="bg-slate-800/50 p-3 rounded-xl border border-emerald-800/50 text-center">
                        <p class="text-xs text-emerald-400 uppercase font-semibold">Growth Speed $f'(x)$</p>
                        <p class="text-xl font-bold text-emerald-400 mt-1" id="out-rate">-- kg/day</p>
                    </div>
                    <div class="md:col-span-3 bg-slate-950 p-3.5 rounded-xl border border-slate-800/80">
                        <span class="text-[11px] font-bold uppercase text-amber-400 tracking-wider block mb-1">What this means in plain words:</span>
                        <p class="text-xs text-slate-300 leading-relaxed font-normal" id="out-explain">
                            Select a data vector above to generate a dynamic agronomic assessment.
                        </p>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <footer class="bg-slate-900 text-slate-400 text-xs py-4 px-4 border-t border-slate-800">
        <div class="max-w-6xl mx-auto flex flex-col md:flex-row justify-between items-center gap-2 text-center md:text-left">
            <p>© 2026 Interactive Agro-Calculus Portal. Developed for Malaysian Bioscience Studies.</p>
            <p>Data Parameters Inspired by: <span class="text-slate-300 underline font-mono">MPOB Palm Oil Yield & Structural Biometrics Reference Pages</span></p>
        </div>
    </footer>

    <script>
        // 1. Math functions for the growth model
        // Logistic function: f(x) = L / (1 + e^(-k(x - x0)))
        const L = 25;    // Maximum carrying capacity / final bunch mass in kg
        const k = 0.25;  // Growth rate coefficient
        const x0 = 15;   // Midpoint day of maximum growth (inflection point)

        function f(x) {
            return L / (1 + Math.exp(-k * (x - x0)));
        }

        function fPrime(x) {
            const expTerm = Math.exp(-k * (x - x0));
            return (L * k * expTerm) / Math.pow(1 + expTerm, 2);
        }

        // 2. Generate Dataset for Days 0 through 30
        const labels = [];
        const dataMass = [];
        const dataRate = [];

        for (let day = 0; day <= 30; day++) {
            labels.push(day);
            dataMass.push(f(day));
            dataRate.push(fPrime(day));
        }

        // 3. Initialize Chart.js with Animation Configs
        const ctx = document.getElementById('growthChart').getContext('2d');
        
        const growthChart = new Chart(ctx, {
            type: 'line',
            data: {
                labels: labels,
                datasets: [
                    {
                        label: 'Total FFB Mass: f(x) (kg)',
                        data: dataMass,
                        borderColor: '#0284c7', // Sky-600
                        backgroundColor: 'rgba(2, 132, 199, 0.05)',
                        borderWidth: 3,
                        fill: true,
                        tension: 0.2,
                        yAxisID: 'yMass',
                        pointRadius: 2,
                        pointHoverRadius: 7,
                        pointHoverBackgroundColor: '#0284c7'
                    },
                    {
                        label: 'Growth Velocity: f\'(x) (kg/day)',
                        data: dataRate,
                        borderColor: '#10b981', // Emerald-500
                        borderDash: [5, 5],
                        borderWidth: 2,
                        fill: false,
                        tension: 0.2,
                        yAxisID: 'yRate',
                        pointRadius: 0, // Keep clean until interactive lookup
                        pointHoverRadius: 5
                    }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                animation: {
                    duration: 1500,
                    easing: 'easeOutQuart'
                },
                plugins: {
                    legend: {
                        position: 'top',
                        labels: {
                            font: { family: 'Plus Jakarta Sans', size: 11, weight: '500' },
                            boxWidth: 12
                        }
                    },
                    tooltip: {
                        mode: 'index',
                        intersect: false,
                        callbacks: {
                            label: function(context) {
                                let label = context.dataset.label.split(':')[0];
                                return ` ${label}: ${context.parsed.y.toFixed(2)}`;
                            }
                        }
                    }
                },
                scales: {
                    x: {
                        title: {
                            display: true,
                            text: 'Time (Days in Ripening Cycle)',
                            color: '#475569',
                            font: { family: 'Plus Jakarta Sans', size: 11, weight: '600' }
                        },
                        grid: { color: '#f1f5f9' }
                    },
                    yMass: {
                        type: 'linear',
                        position: 'left',
                        title: {
                            display: true,
                            text: 'Total Fruit Bunch Weight (kg)',
                            color: '#0284c7',
                            font: { family: 'Plus Jakarta Sans', size: 11, weight: '600' }
                        },
                        min: 0,
                        max: 30,
                        grid: { color: '#f1f5f9' }
                    },
                    yRate: {
                        type: 'linear',
                        position: 'right',
                        title: {
                            display: true,
                            text: 'Accretion Rate (kg / day)',
                            color: '#10b981',
                            font: { family: 'Plus Jakarta Sans', size: 11, weight: '600' }
                        },
                        min: 0,
                        max: 2,
                        grid: { drawOnChartArea: false } // Avoid grid lines overlap
                    }
                },
                onClick: (e) => {
                    // Custom active element parsing on click
                    const activePoints = growthChart.getElementsAtEventForMode(e, 'index', { intersect: false }, true);
                    if (activePoints.length > 0) {
                        const index = activePoints[0].index;
                        const day = labels[index];
                        updateInspector(day);
                    }
                }
            }
        });

        // 4. Interactive Calculus Interpreter Logic
        function updateInspector(day) {
            const mass = f(day);
            const rate = fPrime(day);

            // Toggle panels visible status
            document.getElementById('inspector-prompt').classList.add('hidden');
            document.getElementById('inspector-results').classList.remove('hidden');

            // Populate calculations
            document.getElementById('out-day').innerText = `Day ${day}`;
            document.getElementById('out-mass').innerText = `${mass.toFixed(2)} kg`;
            document.getElementById('out-rate').innerText = `${rate.toFixed(3)} kg/d`;

            // Layman bioscience contextual translation
            let explanation = "";
            if (day < 10) {
                explanation = `Early Lag Phase. At Day ${day}, the fruit bunch is weighing ${mass.toFixed(1)}kg. It is adding weight slowly at just ${rate.toFixed(2)}kg per day. Cell division is occurring inside, but macroscopic accumulation has not fully spiked yet. Holding off harvest is absolutely crucial.`;
            } else if (day >= 10 && day <= 20) {
                if (day === 15) {
                    explanation = `✨ INFLECTION POINT (Day 15)! The derivative $f'(15)$ reaches its absolute maximum at ${rate.toFixed(2)}kg/day. The growth velocity is at its peak right now. This represents the point of maximum metabolic tissue assembly inside the bunch.`;
                } else {
                    explanation = `Exponential Growth Phase. The derivative is highly elevated at ${rate.toFixed(2)}kg/day. The palm bunch is packing on biomass rapidly. Any structural moisture stresses or fertilizer deficits right now will significantly reduce final yield output.`;
                }
            } else {
                explanation = `Asymptotic Saturation Phase. The growth derivative drops to ${rate.toFixed(2)}kg/day, showing a sharp deceleration in weight gain even though total mass is high (~${mass.toFixed(1)}kg). The bunch has maximized sugar/oil storage. Biologically, it is entering full ripeness for processing!`;
            }

            document.getElementById('out-explain').innerHTML = explanation;
        }
    </script>

    <script>
        window.MathJax = {
            tex: {
                inlineMath: [['$', '$'], ['\\(', '\\)']],
                displayMath: [['$$', '$$'], ['\\[', '\\]']]
            },
            svg: { fontCache: 'global' }
        };
    </script>
    <script id="MathJax-script" async src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-mml-chtml.js"></script>
</body>
</html>
